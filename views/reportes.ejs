    <style>
      /* =============================================
         MEJORAS VISUALES
      ============================================= */

      /* Header badge mango */
      .hm-badge { display:flex; align-items:center; gap:8px; }
      .hm-badge .hm-icon { width:28px;height:28px;flex-shrink:0;background:linear-gradient(135deg,#f5a800,#e06800);border-radius:6px;display:flex;align-items:center;justify-content:center; }
      .hm-badge .hm-text { font-weight:700; font-size:13px; white-space:nowrap; }

      /* Loader mango */
      .loader-indices { background: linear-gradient(160deg, #0f2208 0%, #1b3d10 60%, #2e6318 100%) !important; }
      .text-loader-container h2 { font-family:'Montserrat',sans-serif; font-weight:800; font-size:28px; color:#fff !important; letter-spacing:0.04em; }
      .text-loader-container h2 span { color:#f5a800; }

      /* Panel izquierdo — logo section */
      .logo-section { background:linear-gradient(135deg,#1b3d10,#2e6318); border-radius:10px; overflow:hidden; }

      /* Título módulo */
      .title-module-section { border-left:3px solid #f59800; padding-left:10px; margin-bottom:20px; }
      .item-title-module small { font-size:10px;color:#888;text-transform:uppercase;letter-spacing:0.06em; }
      .item-title-module h5 { font-size:15px;font-weight:700;margin-top:2px; }

      /* Filtros — subtítulos */
      .filtros-container h6 {
        font-size: 10.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: #888;
        margin-bottom: 6px;
        padding-bottom: 4px;
        border-bottom: 1px solid #f0f0f0;
      }

      /* Botones panel izquierdo */
      .btn-previsualizar-reporte {
        background: rgba(245,168,0,0.08) !important;
        border: 1px solid rgba(245,168,0,0.35) !important;
        color: #c96800 !important;
        font-weight: 600 !important;
        border-radius: 8px;
        font-size: 13px;
        transition: background 0.18s;
      }
      .btn-previsualizar-reporte:hover { background: rgba(245,168,0,0.18) !important; }

      .btn-descargar-reporte,
      .btn-descargar-kml {
        border-radius: 8px !important;
        font-size: 13px !important;
        font-weight: 600 !important;
      }

      /* Panel derecho — card header mejorado */
      .modulo-title-section {
        border-bottom: 2px solid #f5f5f5;
        padding: 20px 24px !important;
      }
      .modulo-title-section h4 {
        font-family: 'Montserrat', sans-serif;
        font-size: 16px;
        font-weight: 800;
        color: #1b3d10;
        letter-spacing: 0.06em;
        margin-bottom: 4px;
        position: relative;
        padding-left: 12px;
      }
      .modulo-title-section h4::before {
        content: '';
        position: absolute;
        left: 0; top: 1px; bottom: 1px;
        width: 4px;
        background: linear-gradient(to bottom, #f5a800, #e06800);
        border-radius: 2px;
      }
      .modulo-title-section small { color: #888; font-size: 12.5px; }

      /* Botón filtrar campos */
      .btn-vista-sostenibilidad-reporte {
        background: linear-gradient(135deg, #f5a800, #e06800) !important;
        border: none !important;
        color: #fff !important;
        border-radius: 7px !important;
        font-size: 12px !important;
        font-weight: 600 !important;
        padding: 6px 14px !important;
        box-shadow: 0 2px 8px rgba(245,152,0,0.3);
      }

      /* Tabla previsualización */
      .table-previsualizacion .table thead tr th {
        background: #f8f9fa;
        font-size: 10px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: #666; border-bottom: 2px solid #e9ecef;
        padding: 8px 10px; white-space: nowrap;
      }
      .table-previsualizacion .table tbody tr td {
        padding: 8px 10px; vertical-align: middle;
        font-size: 12.5px; border-bottom: 1px solid #f3f3f3;
        color: #555;
      }
      .table-previsualizacion .table tbody tr td.placeholder {
        color: #aaa; font-style: italic; font-size: 12px;
      }
      .table-previsualizacion .table tbody tr:hover td { background: #fffbf5; }

      /* Label "Filtrar campos" */
      .label-filtrar { font-size: 12px; font-weight: 600; color: #888; margin-right: 12px; display: flex; align-items: center; }
    </style>
  </head>

  <body>
