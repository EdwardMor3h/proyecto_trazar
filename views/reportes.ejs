      <div class="text-loader-container">
        <h2>geo<span>farms</span></h2>
        <h6 style="color:#ffc046;">🥭 Sistema de Parcelas de Mango</h6>
        <small style="color:rgba(255,255,255,0.5);">Lambayeque · Perú</small>
