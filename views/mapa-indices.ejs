    <style>
      /* =============================================
         ESTILOS ORIGINALES — copiados sin cambios
      ============================================= */
      .table-container {
        position: absolute; bottom: 1%; background-color: #EEE; z-index:10;
        display: flex; justify-content: center; border-radius: 10px;
        height: auto; width: 98%; left: 1%; padding: 1rem;
      }
      .table-actualizar-datos { width: 100%; }
      .table-actualizar-datos tbody tr td { border-bottom-width: 0px; }
      .table { width: 100%; border-collapse: collapse; }
      th, td { padding: 8px; text-align: left; border-bottom: 1px solid #ddd; }
      .table thead { position: sticky; top: 0; background-color: #f2f2f2; }
      .table thead th { position: sticky; top: 0; }
      th { position: sticky; top: 0; background-color: #f2f2f2; z-index: 1; }
      .pagination-container { display: flex; justify-content: space-between; position: absolute; bottom: 0; background-color: #f2f2f2; padding: 8px; z-index: 1; }
      .div-alert { position: absolute; bottom: 1%; z-index:10; width: 98%; left: 1%; display: none; font-size: 14px; }
      .btn-descargar-container { position: absolute; width: 100%; display: flex; justify-content: center; z-index: 999; }

      /* =============================================
         MEJORAS VISUALES
      ============================================= */

      /* Loader mejorado — mango temático */
      .loader-indices {
        background: linear-gradient(160deg, #0f2208 0%, #1b3d10 60%, #2e6318 100%) !important;
      }
      .text-loader-container h2 {
        font-family: 'Montserrat', sans-serif;
        font-weight: 800;
        font-size: 28px;
        color: #fff !important;
        letter-spacing: 0.04em;
      }
      .text-loader-container h2 span { color: #f5a800; }

      /* Header badge mango */
      .hm-badge { display:flex; align-items:center; gap:8px; }
      .hm-badge .hm-icon {
        width:30px; height:30px; flex-shrink:0;
        background:linear-gradient(135deg,#f5a800,#e06800);
        border-radius:7px;
        display:flex; align-items:center; justify-content:center;
      }
      .hm-badge .hm-text { font-weight:700; font-size:13px; white-space:nowrap; }

      /* Panel izquierdo — título módulo */
      .title-module-section {
        border-left: 3px solid #f59800;
        padding-left: 10px;
        margin-bottom: 20px;
      }
      .item-title-module small { font-size:10px; color:#888; text-transform:uppercase; letter-spacing:0.06em; }
      .item-title-module h5 { font-size:15px; font-weight:700; margin-top:2px; }

      /* Subtítulos de secciones */
      .buscador-parcela-section h6,
      .periodo-section h6,
      .fechas-section h6,
      .parcela-consultada-section h6,
      .indice-espectral-section h6,
      .parametros-section h6 {
        font-size: 10.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #888;
        padding-bottom: 6px;
        border-bottom: 1px solid #f0f0f0;
        margin-bottom: 0;
      }

      /* Botones período predefinido */
      .btn-periodo-predefinido-01,
      .btn-periodo-predefinido-02,
      .btn-periodo-predefinido-03 {
        border: 1px solid rgba(245,168,0,0.35) !important;
        color: #c96800 !important;
        background: rgba(245,168,0,0.07) !important;
        border-radius: 6px;
        font-size: 11.5px;
        font-weight: 500;
        transition: background 0.18s;
      }
      .btn-periodo-predefinido-01:hover,
      .btn-periodo-predefinido-02:hover,
      .btn-periodo-predefinido-03:hover {
        background: rgba(245,168,0,0.15) !important;
      }

      /* Botón volver */
      .btn-back { font-size: 13px; }

      /* Logo section en panel izquierdo */
      .logo-section {
        background: linear-gradient(135deg, #1b3d10, #2e6318);
        border-radius: 10px;
        overflow: hidden;
      }
    </style>
  </head>

  <body style="height:100% !important;">

