    <style>

      /* Header logo — reemplaza imagen por badge mango */
      .header-logo-wrapper .logo-wrapper {
        display: flex;
        align-items: center;
        padding: 4px 8px;
      }
      .hm-badge {
        display: flex; align-items: center; gap: 8px;
      }
      .hm-badge .hm-icon {
        width: 28px; height: 28px; flex-shrink: 0;
        background: linear-gradient(135deg, #f5a800, #e06800);
        border-radius: 6px;
        display: flex; align-items: center; justify-content: center;
      }
      .hm-badge .hm-text {
        font-weight: 700; font-size: 13px; white-space: nowrap;
      }

      /* Título módulo — borde izquierdo naranja */
      .title-module-section {
        border-left: 3px solid #f59800;
        padding-left: 10px;
        margin-bottom: 20px;
      }
      .item-title-module small {
        font-size: 10px; color: #888;
        text-transform: uppercase; letter-spacing: 0.06em;
      }
      .item-title-module h5 { font-size: 15px; font-weight: 700; margin-top: 2px; }

      /* Secciones datos del panel izquierdo */
      .nuevos-datos-section h6 {
        font-size: 10.5px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.08em;
        color: #888; padding-bottom: 6px;
        border-bottom: 1px solid #f0f0f0; margin-bottom: 0;
      }
      .items-menu-container ul { list-style: none; padding: 0; margin: 0; }
      .items-menu-container ul li { margin-bottom: 2px; }
      .items-menu-container ul li a {
        display: flex; align-items: center; gap: 8px;
        padding: 7px 10px; border-radius: 7px;
        font-size: 13px; color: inherit;
        text-decoration: none;
        transition: background 0.18s, color 0.18s;
      }
      .items-menu-container ul li a:hover {
        background: #fff8ed; color: #e07000;
      }
      .items-menu-container ul li a.active {
        background: linear-gradient(135deg, rgba(245,168,0,0.15), rgba(245,168,0,0.07));
        color: #c96800; font-weight: 600;
        border-left: 3px solid #f59800; padding-left: 7px;
      }
      .items-menu-container ul li a i {
        font-size: 12px; width: 14px;
        text-align: center; color: #f59800;
      }

      /* Panel derecho — encabezado de sección */
      .section-header-mango {
        display: flex; align-items: center;
        justify-content: space-between;
        margin-bottom: 20px; padding-bottom: 14px;
        border-bottom: 2px solid #f5f5f5;
      }
      .section-header-mango .sh-left { display: flex; align-items: center; gap: 12px; }
      .section-header-mango .sh-icon {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, #f5a800, #e06800);
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 2px 8px rgba(245,152,0,0.3);
        flex-shrink: 0;
      }
      .section-header-mango .sh-text h5  { font-size: 16px; font-weight: 700; margin: 0; }
      .section-header-mango .sh-text small { color: #888; font-size: 12px; }

      /* Tabla mejorada */
      .table-actualizar-datos .table thead tr th {
        background: #f8f9fa; font-size: 11px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.07em;
        color: #666; border-bottom: 2px solid #e9ecef;
        padding: 10px 14px;
      }
      .table-actualizar-datos .table tbody tr td {
        padding: 10px 14px; vertical-align: middle;
        font-size: 13.5px; border-bottom: 1px solid #f3f3f3;
      }
      .table-actualizar-datos .table tbody tr:hover td { background: #fffbf5; }

      /* ID badge */
      .id-badge {
        display: inline-flex; align-items: center; justify-content: center;
        width: 28px; height: 28px;
        background: #fff3d6; color: #b36800;
        border-radius: 6px; font-size: 12px; font-weight: 700;
      }

      /* footer-section alineado a la derecha */
      .footer-section {
        display: flex; justify-content: flex-end; margin-bottom: 12px;
      }

    </style>
