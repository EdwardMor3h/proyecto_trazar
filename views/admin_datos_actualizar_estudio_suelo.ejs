                  <li><a href="email_read.html"><p><i class="fa fa-circle-o me-3 font-danger"></i>Solicitud EVI<span class="pull-right">6 hr</span></p></a></li>
                  <li><a class="btn btn-primary" href="email_read.html">Ver más</a></li>
                </ul>
              </li>
            </ul>
          </div>

          <script class="result-template" type="text/x-handlebars-template">
            <div class="ProfileCard u-cf">
            <div class="ProfileCard-avatar"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-airplay m-0"><path d="M5 17H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-1"></path><polygon points="12 15 17 21 7 21 12 15"></polygon></svg></div>
            <div class="ProfileCard-details"><div class="ProfileCard-realName">{{name}}</div></div>
            </div>
          </script>
          <script class="empty-template" type="text/x-handlebars-template">
            <div class="EmptyMessage">Your search turned up 0 results. This most likely means the backend is down, yikes!</div>
          </script>
        </div>
      </div>

      <div class="page-body-wrapper">

        <%- include('./partials/menu_lateral'); %>

        <div class="page-body">
          <div class="container-fluid">
            <div class="row h-100 m-0">

              <!-- PANEL IZQUIERDO -->
              <div class="col-xl-3 col-md-3 box-col-30 xl-30 info-section">
                <div class="card">
                  <div class="card-body">
                    <div class="logo-section mb-4">
                      <div class="logo-container">
                        <div style="width:32px;height:32px;background:linear-gradient(135deg,#f5a800,#e06800);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                          <svg width="17" height="17" viewBox="0 0 32 32" fill="none">
                            <path d="M16 6C10 6,5 11,5 17.5C5 23.5,10 28,16 28C22 28,27 23.5,27 17.5C27 11,22 6,16 6Z" fill="rgba(255,255,255,0.93)"/>
                            <path d="M16 6C16 6,17.5 2.5,21.5 3.5" stroke="rgba(255,255,255,0.65)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
                          </svg>
                        </div>
                        <div>
                          <span>Parcelas de Mango</span>
                          <small>Sistema de Información</small>
                        </div>
                      </div>
                      <%- include('./partials/user_profile'); %>
                    </div>
                    <div class="title-module-section">
                      <div class="group-title-module" style="display:flex;">
                        <a class="a-open-menu" style="margin-right:10px; margin-top:2px;">
                          <span class="fa fa-bars"></span>
                        </a>
                        <div class="item-title-module">
                          <small>Módulo</small>
                          <h5 class="mb-0">Administración de Datos</h5>
                        </div>
                      </div>
                    </div>
                    <div class="options-section">
                      <div class="buscador-periodo-ie-section">
                        <%- include('./partials/admin_menu'); %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- PANEL DERECHO -->
              <div class="col-xl-9 col-md-9 box-col-70 xl-70 admin-data-section">
                <div class="card">
                  <div class="card-body p-5">

                    <!-- Encabezado -->
                    <div class="section-header-mango">
                      <div class="sh-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M2 22h20"/>
                          <path d="M6 18V8"/>
                          <path d="M10 18V4"/>
                          <path d="M14 18V10"/>
                          <path d="M18 18V14"/>
                        </svg>
                      </div>
                      <div class="sh-text">
                        <h5>Actualizar Estudio de Suelo</h5>
                        <small>Busca una parcela y actualiza los parámetros del estudio de suelo</small>
                      </div>
                    </div>

                    <!-- Buscador de parcelas -->
                    <div class="buscador-card">
                      <h6><i class="fa fa-search me-2"></i>Buscador de Parcelas</h6>
                      <div class="search">
                        <form class="form-inline w-50">
                          <div class="form-group d-flex mb-0 w-100 ui search">
                            <i class="fa fa-search"></i>
                            <input class="form-control-plaintext input-buscar-parcela" type="text" placeholder="Ingresa el nombre, código o DNI">
                            <div class="dropdown-content">
                              <ul class="list-group list-group-flush list"></ul>
                            </div>
                          </div>
                        </form>
                      </div>
                    </div>

                    <!-- Formulario de campos -->
                    <div class="row">

                      <!-- Columna izquierda -->
                      <div class="col-xl-6 col-md-6 box-col-50 xl-50">

                        <div class="field-group">
                          <label class="field-label">Fecha de Estudio</label>
                          <div class="search">
                            <form class="form-inline w-100">
                              <div class="form-group d-flex mb-0 w-100 ui search">
                                <i class="fa fa-calendar"></i>
                                <input class="form-control-plaintext datepicker-here form-control digits input-fecha-actualizar-estudio-suelo" type="text" data-language="en" placeholder="Seleccionar Fecha de Estudio" required>
                              </div>
                            </form>
                          </div>
                        </div>

                        <div class="field-group">
                          <label class="field-label">Código</label>
                          <div class="search">
                            <form class="form-inline w-100">
                              <div class="form-group d-flex mb-0 w-100 ui search">
                                <i class="fa fa-barcode"></i>
                                <input class="form-control-plaintext input-codigo-actualizar-estudio-suelo" type="text" placeholder="Ingresar código">
                              </div>
                            </form>
                          </div>
                        </div>

                        <div class="field-group">
                          <label class="field-label">Textura</label>
                          <select id="select-input-textura-suelo-actualizar-estudio-suelo" class="js-example-basic-single input-select col-sm-12" data-model="texturas-suelo" data-id=""></select>
                        </div>

                        <div class="field-group">
                          <label class="field-label">Materia Orgánica <span class="field-unit">(%)</span></label>
                          <div class="search">
                            <form class="form-inline w-100">
                              <div class="form-group d-flex mb-0 w-100 ui search">
                                <i class="fa fa-leaf"></i>
                                <input class="form-control-plaintext input-materia-organica-actualizar-estudio-suelo" type="text" placeholder="Ingresar materia orgánica">
                              </div>
                            </form>
                          </div>
                        </div>

                      </div>

                      <!-- Columna derecha -->
                      <div class="col-xl-6 col-md-6 box-col-50 xl-50 col-divider">

                        <div class="field-group">
                          <label class="field-label">Potencial de Hidrógeno <span class="field-unit">(pH)</span></label>
                          <div class="search">
                            <form class="form-inline w-100">
                              <div class="form-group d-flex mb-0 w-100 ui search">
                                <i class="fa fa-flask"></i>
                                <input class="form-control-plaintext input-ph-actualizar-estudio-suelo" type="text" placeholder="Ingresar pH">
                              </div>
                            </form>
                          </div>
                        </div>

                        <div class="field-group">
                          <label class="field-label">Nitrato <span class="field-unit">(NO₃)</span></label>
                          <div class="search">
                            <form class="form-inline w-100">
                              <div class="form-group d-flex mb-0 w-100 ui search">
                                <i class="fa fa-atom"></i>
                                <input class="form-control-plaintext input-nitrato-actualizar-estudio-suelo" type="text" placeholder="Ingresar nitrato">
                              </div>
                            </form>
                          </div>
                        </div>

                        <div class="field-group">
                          <label class="field-label">Fósforo <span class="field-unit">(P)</span></label>
                          <div class="search">
                            <form class="form-inline w-100">
                              <div class="form-group d-flex mb-0 w-100 ui search">
                                <i class="fa fa-atom"></i>
                                <input class="form-control-plaintext input-fosforo-actualizar-estudio-suelo" type="text" placeholder="Ingresar fósforo">
                              </div>
                            </form>
                          </div>
                        </div>

                        <div class="field-group">
                          <label class="field-label">Óxido de Potasio <span class="field-unit">(K₂O)</span></label>
                          <div class="search">
                            <form class="form-inline w-100">
                              <div class="form-group d-flex mb-0 w-100 ui search">
                                <i class="fa fa-atom"></i>
                                <input class="form-control-plaintext input-oxido-potasio-actualizar-estudio-suelo" type="text" placeholder="Ingresar óxido de potasio">
                              </div>
                            </form>
                          </div>
                        </div>

                        <!-- Botón actualizar — clase original intacta -->
                        <div class="footer-section" style="position:relative; padding-left:0; justify-content:flex-start; margin-top:8px;">
                          <button class="btn btn-primary btn-actualizar-estudio-suelo" type="button" disabled>
                            <i class="fa fa-save me-2"></i>Actualizar
                          </button>
                        </div>

                      </div>

                    </div>

                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- Footer — sin cambios -->
        <footer class="footer">
          <div class="container-fluid">
            <div class="row">
              <div class="col-md-6 p-0 footer-left">
                <p class="mb-0">Copyright© 2026 TraZar. Todos los derechos</p>
              </div>
            </div>
          </div>
        </footer>

      </div>
    </div>

