    <style>
      /* === Originales — sin cambios === */
      .success { color: #30E85B !important; font-weight: 500 !important; }
      .error   { color: red !important;    font-weight: 500 !important; }
      .table td { font-weight: 300; }
      .btn-complementary { font-weight: 500; }
      td.options { display:flex; justify-content:center; align-items:center; }
      td.options a:nth-child(2) { margin-left: 0.5rem; }

      /* === Mejoras visuales === */
      .hm-badge { display:flex; align-items:center; gap:8px; }
      .hm-badge .hm-icon { width:28px;height:28px;flex-shrink:0;background:linear-gradient(135deg,#f5a800,#e06800);border-radius:6px;display:flex;align-items:center;justify-content:center; }
      .hm-badge .hm-text { font-weight:700; font-size:13px; white-space:nowrap; }

      /* Encabezado de sección */
      .status-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 20px;
        padding-bottom: 14px;
        border-bottom: 2px solid #f5f5f5;
      }
      .status-header .sh-icon {
        width: 42px; height: 42px; flex-shrink: 0;
        background: linear-gradient(135deg, #f5a800, #e06800);
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 2px 8px rgba(245,152,0,0.3);
      }
      .status-header .sh-text h5 { font-size:16px; font-weight:700; margin:0; }
      .status-header .sh-text small { color:#888; font-size:12px; }

      /* Tabla mejorada */
      .table-actualizar-datos .table thead tr th {
        background: #f8f9fa;
        font-size: 11px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.07em;
        color: #666; border-bottom: 2px solid #e9ecef;
        padding: 10px 14px;
      }
      .table-actualizar-datos .table tbody tr td {
        padding: 10px 14px; vertical-align: middle;
        font-size: 13px; border-bottom: 1px solid #f3f3f3;
      }
      .table-actualizar-datos .table tbody tr:hover td { background: #fffbf5; }

      /* Mapa con borde */
      #map {
        border-radius: 10px;
        border: 1px solid #f0e0c0;
        min-height: 400px;
        height: 100%;
      }
    </style>
