    <div class="page-wrapper compact-wrapper" id="pageWrapper">

      <!-- Page Header -->
      <div class="page-header">
        <div class="header-wrapper row m-0">

          <div class="header-logo-wrapper col-auto p-0">
            <div class="logo-wrapper">
              <div class="hm-badge">
                <div class="hm-icon">
                  <svg width="15" height="15" viewBox="0 0 32 32" fill="none">
                    <path d="M16 6C10 6,5 11,5 17.5C5 23.5,10 28,16 28C22 28,27 23.5,27 17.5C27 11,22 6,16 6Z" fill="rgba(255,255,255,0.93)"/>
                    <path d="M16 6C16 6,17.5 2.5,21.5 3.5" stroke="rgba(255,255,255,0.65)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
                  </svg>
                </div>
                <span class="hm-text">Parcelas de Mango</span>
              </div>
            </div>
            <div class="toggle-sidebar"><i class="status_toggle middle sidebar-toggle" data-feather="align-center"></i></div>
          </div>

          <div class="left-header col-7 horizontal-wrapper ps-0">
            <a class="sidebar-link sidebar-title" href="javascript:void(0)"><i data-feather="bar-chart"></i><span>Dashboard</span></a>
            <a class="sidebar-link sidebar-title" href="javascript:void(0)"><i data-feather="map"></i><span>Monitoreo</span></a>
            <a class="sidebar-link sidebar-title" href="javascript:void(0)"><i data-feather="layers"></i><span>Coberturas</span></a>
            <a class="sidebar-link sidebar-title" href="javascript:void(0)"><i data-feather="file-text"></i><span>Reportes</span></a>
          </div>

          <script class="result-template" type="text/x-handlebars-template">
            <div class="ProfileCard u-cf"><div class="ProfileCard-avatar"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-airplay m-0"><path d="M5 17H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-1"></path><polygon points="12 15 17 21 7 21 12 15"></polygon></svg></div><div class="ProfileCard-details"><div class="ProfileCard-realName">{{name}}</div></div></div>
          </script>
          <script class="empty-template" type="text/x-handlebars-template"><div class="EmptyMessage">Your search turned up 0 results. This most likely means the backend is down, yikes!</div></script>
        </div>
      </div>

      <div class="page-body-wrapper">
        <%- include('./partials/menu_lateral'); %>

        <div class="page-body">
          <div class="container-fluid">
            <div class="row h-100 m-0">

              <!-- ============================================
                   PANEL IZQUIERDO — filtros
              ============================================ -->
              <div class="col-xl-3 col-md-3 box-col-30 xl-30 info-section" style="height:100%;">
                <div class="card mb-0">
                  <div class="card-body">

                    <!-- Banner mango + user_profile partial — sin cambios -->
                    <div class="logo-section mb-4">
                      <%- include('./partials/user_profile'); %>
                    </div>

                    <!-- Título módulo -->
                    <div class="title-module-section">
                      <div class="group-title-module" style="display:flex;">
                        <a class="a-open-menu" style="margin-right:10px; margin-top:2px;"><span class="fa fa-bars"></span></a>
                        <div class="item-title-module">
                          <small>Módulo</small>
                          <h5 class="mb-0">Reportes</h5>
                        </div>
                      </div>
                    </div>

                    <!-- Filtros — IDs y clases EJS 100% intactos -->
                    <div class="filtros-container">

                      <div class="mb-4">
                        <h6 class="mb-0">Variedad</h6>
                        <select id="select-filtro-variedad" class="js-variedad-multiple col-sm-12" multiple="multiple"></select>
                      </div>

                      <div class="mb-4">
                        <h6 class="mb-0">Altitud</h6>
                        <select id="select-filtro-altitud" class="js-altitud-multiple col-sm-12 mt-3" multiple="multiple"></select>
                      </div>

                      <% if (user && user.rol != 3) { %>
                      <div class="mb-4">
                        <h6 class="mb-0">Zona</h6>
                        <select id="select-filtro-zona" class="js-zona-multiple col-sm-12" multiple="multiple"></select>
                      </div>
                      <% } %>

                      <div class="mb-4">
                        <h6 class="mb-0">Corredor</h6>
                        <select id="select-filtro-corredor" class="js-corredor-multiple col-sm-12" multiple="multiple"></select>
                      </div>

                      <div class="mb-4">
                        <h6 class="mb-0">Comité</h6>
                        <select id="select-filtro-comite" class="js-comite-multiple col-sm-12" multiple="multiple"></select>
                      </div>

                      <div class="mb-4">
                        <h6 class="mb-0">Cuenca Hidrográfica</h6>
                        <select id="select-filtro-cuenca-hidrografica" class="js-cuenca-hidrografica-multiple col-sm-12" multiple="multiple"></select>
                      </div>

                      <div class="mb-4">
                        <h6 class="mb-0">Códigos de Venta</h6>
                        <select id="select-filtro-codigo-venta" class="js-codigo-venta-multiple col-sm-12"></select>
                      </div>

                    </div>

                    <!-- Botones — clases originales intactas -->
                    <div class="w-100 btn-previsualizar-descargar-container d-flex flex-column">

                      <div class="w-75 mb-3 g-3 text-left actualizar-btn-container">
                        <button class="w-100 btn btn-back btn-sm btn-previsualizar-reporte" type="button">
                          <i class="fa fa-eye me-2"></i>Previsualizar
                        </button>
                      </div>

                      <% if (user && user.rol != 3) { %>
                      <div class="w-75 mb-3 g-3 text-left actualizar-btn-container">
                        <button class="w-100 btn btn-primary btn-sm btn-descargar-reporte" type="button">
                          <i class="fa fa-file-excel me-2"></i>Descargar xls
                        </button>
                      </div>
                      <% } %>

                      <% if (user && user.rol != 3) { %>
                      <div class="w-75 mb-3 g-3 text-left actualizar-btn-container">
                        <a href="/obtener_parcelas_cafe_kml">
                          <button class="w-100 btn btn-primary btn-sm btn-descargar-kml" type="button">
                            <i class="fa fa-map me-2"></i>Descargar kml
                          </button>
                        </a>
                      </div>
                      <% } %>

                    </div>

                  </div>
                </div>
              </div>

              <!-- ============================================
                   PANEL DERECHO — tabla previsualización
              ============================================ -->
              <div class="col-xl-9 col-md-9 box-col-70 xl-70 p-0 resultados-container">
                <div class="card mb-0" style="border-radius:0;">

                  <div class="card-header modulo-title-section">
                    <h4 class="text-uppercase">Reporte de Parcelas</h4>
                    <small>Consulta y filtra las unidades productivas de mango a partir de diferentes criterios</small>

                    <div class="w-100 mt-4 btn-previsualizar-descargar-container d-flex align-items-center">
                      <span class="label-filtrar">Filtrar Campos:</span>
                      <div class="g-3 text-left actualizar-btn-container">
                        <!-- id="nextBtn" original intacto -->
                        <button class="w-100 btn btn-view btn-xs btn-vista-sostenibilidad-reporte" id="nextBtn" type="button">
                          <i class="fa fa-sliders me-2"></i>Sostenibilidad
                        </button>
                      </div>
                    </div>
                  </div>

                  <div class="card-body">
                    <!-- id="table-previsualizacion" intacto -->
                    <div class="table-responsive table-previsualizacion">
                      <table class="table" id="table-previsualizacion">
                        <thead>
                          <tr class="border-bottom-dark">
                            <th scope="col">Código<br>Parcela</th>
                            <th scope="col">Parcela</th>
                            <th scope="col">Código<br>Productor</th>
                            <th scope="col">Productor</th>
                            <th scope="col">Variedad</th>
                            <th scope="col">Altitud</th>
                            <th scope="col">Sello</th>
                            <th scope="col">Extensionista</th>
                            <th scope="col">Promotor</th>
                            <th scope="col">Corredor</th>
                            <th scope="col">Comite</th>
                            <th scope="col">Zona</th>
                            <th scope="col">Cuenca</th>
                            <th scope="col">Caserio</th>
                            <th scope="col">Código<br>Venta</th>
                            <th scope="col">Area ha<br>Manual</th>
                            <th scope="col">Area ha<br>Calc</th>
                            <th scope="col">ANP</th>
                            <th scope="col">ANP<br>m2</th>
                            <th scope="col">ANP<br>%</th>
                            <th scope="col">Zona<br>Amort.</th>
                            <th scope="col">ZA<br>m2</th>
                            <th scope="col">ZA<br>%</th>
                            <th scope="col">Def. 2014</th>
                            <th scope="col">DEF14<br>m2</th>
                            <th scope="col">DEF14<br>%</th>
                            <th scope="col">Def. 2020</th>
                            <th scope="col">DEF20<br>m2</th>
                            <th scope="col">DEF20<br>%</th>
                            <th scope="col">Intersect.<br>Parcelas</th>
                            <th scope="col">Intersect.<br>Parcelas m2</th>
                            <th scope="col">Intersect.<br>Parcelas %</th>
