                          <div class="mt-3 items-fechas-section">
                            <div class="d-flex mb-4">
                              <label class="col-form-label m-r-10"><i class="fa fa-satellite"></i> &nbsp 09 de Noviembre del 2022</label>
                              <div class="flex-grow-1 text-end icon-state">
                                <label class="switch switch-fechas-disponibles"><input type="checkbox" value="09-11-22"><span class="switch-state"></span></label>
