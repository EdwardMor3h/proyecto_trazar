                          <h5 class="mb-0">Monitoreo de Parcelas</h5>
                        </div>
                      </div>
                    </div>

                    <!-- Opciones — todo intacto, solo títulos mejorados por CSS -->
                    <div class="options-section">

                      <div class="buscador-periodo-ie-section">

                        <!-- Buscador -->
                        <div class="buscador-parcela-section mb-5">
                          <h6 class="mb-0">Buscador de Parcelas</h6>
                          <div class="search mt-3">
                            <form class="form-inline w-100">
                              <div class="form-group d-flex mb-0 w-100 ui search">
                                <i class="fa fa-search"></i>
                                <input class="form-control-plaintext input-buscar-parcela" type="text" placeholder="Ingresa el nombre, código o DNI">
                                <div class="dropdown-content">
                                  <ul class="list-group list-group-flush list"></ul>
                                </div>
                                <div class="spinner" style="display:none;"></div>
                              </div>
                            </form>
                          </div>
                        </div>

                        <!-- Período -->
                        <div class="periodo-section">
                          <h6 class="mb-0">Período de Análisis</h6>
                          <div class="periodos-buttons-section mt-3">
                            <button class="btn btn-sm btn-periodo-predefinido-01" type="button">Últimos 12 meses</button>
                            <button class="btn btn-sm btn-periodo-predefinido-02" type="button">2021</button>
                            <button class="btn btn-sm btn-periodo-predefinido-03" type="button">2020</button>
                          </div>
                          <div class="mt-3">
                            <form class="form-inline w-100">
                              <div class="form-group d-flex mb-0 w-100 ui search">
                                <i class="fa fa-calendar"></i>
                                <input class="form-control-plaintext datepicker-here form-control digits input-periodo" type="text" data-range="true" data-multiple-dates-separator=" - " data-language="en" placeholder="Seleccionar Período">
                              </div>
                            </form>
                          </div>
                        </div>

                        <div class="footer-section">
                          <button class="btn btn-primary btn-consultar-periodo" type="button">
                            <i class="fa fa-satellite me-1"></i> Consultar
                          </button>
                        </div>

                      </div>
                      <!-- ./buscador-periodo-ie-section -->

