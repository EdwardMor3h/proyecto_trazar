    <link rel="stylesheet" type="text/css" href="../assets/css/style.css">
    <link id="color" rel="stylesheet" href="../assets/css/color-1.css" media="screen">
    <link rel="stylesheet" type="text/css" href="../assets/css/responsive.css">

    <script src="https://unpkg.com/maplibre-gl@2.4.0/dist/maplibre-gl.js"></script>
    <link href="https://unpkg.com/maplibre-gl@2.4.0/dist/maplibre-gl.css" rel="stylesheet" />
    <link rel="stylesheet" type="text/css" href="../assets/css/altomayo-v2-style.css">
    <script src='https://unpkg.com/@turf/turf@6/turf.min.js'></script>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

    <style>
      /* === Mapa — original intacto === */
      .map-container {
        height: 400px;
        margin-top: 1rem;
      }
      #map {
        border-radius: 10px;
      }
      .mapboxgl-ctrl.mapboxgl-ctrl-attrib,
      .maplibregl-ctrl.maplibregl-ctrl-attrib {
        background-color: hsla(0,0%,100%,.5);
      }

      /* === Header badge mango === */
      .hm-badge { display:flex; align-items:center; gap:8px; }
      .hm-badge .hm-icon {
        width:28px; height:28px; flex-shrink:0;
        background:linear-gradient(135deg,#f5a800,#e06800);
        border-radius:6px;
        display:flex; align-items:center; justify-content:center;
      }
      .hm-badge .hm-text { font-weight:700; font-size:13px; white-space:nowrap; }

      /* === Título módulo === */
      .title-module-section {
        border-left: 3px solid #f59800;
        padding-left: 10px;
        margin-bottom: 20px;
      }
      .item-title-module small { font-size:10px; color:#888; text-transform:uppercase; letter-spacing:0.06em; }
      .item-title-module h5    { font-size:15px; font-weight:700; margin-top:2px; }

      /* === Menú lateral izquierdo === */
      .nuevos-datos-section h6 {
        font-size:10.5px; font-weight:700; text-transform:uppercase;
        letter-spacing:0.08em; color:#888;
        padding-bottom:6px; border-bottom:1px solid #f0f0f0; margin-bottom:0;
      }
      .items-menu-container ul { list-style:none; padding:0; margin:0; }
      .items-menu-container ul li { margin-bottom:2px; }
      .items-menu-container ul li a {
        display:flex; align-items:center; gap:8px;
        padding:7px 10px; border-radius:7px;
        font-size:13px; color:inherit; text-decoration:none;
        transition:background 0.18s, color 0.18s;
      }
      .items-menu-container ul li a:hover { background:#fff8ed; color:#e07000; }
      .items-menu-container ul li a.active {
        background:linear-gradient(135deg,rgba(245,168,0,0.15),rgba(245,168,0,0.07));
        color:#c96800; font-weight:600;
        border-left:3px solid #f59800; padding-left:7px;
      }
      .items-menu-container ul li a i { font-size:12px; width:14px; text-align:center; color:#f59800; }

      /* === Panel derecho — encabezado === */
      .section-header-mango {
        display:flex; align-items:center; gap:14px;
        margin-bottom:24px; padding-bottom:16px;
        border-bottom:2px solid #f5f5f5;
      }
      .section-header-mango .sh-icon {
        width:42px; height:42px; flex-shrink:0;
        background:linear-gradient(135deg,#f5a800,#e06800);
        border-radius:10px;
        display:flex; align-items:center; justify-content:center;
        box-shadow:0 2px 8px rgba(245,152,0,0.3);
      }
      .section-header-mango .sh-text h5  { font-size:16px; font-weight:700; margin:0; }
      .section-header-mango .sh-text small { color:#888; font-size:12px; }

      /* === Subsecciones del formulario === */
      .form-subsection h6 {
        font-size:11px; font-weight:700; text-transform:uppercase;
        letter-spacing:0.07em; color:#888;
        padding-bottom:6px; border-bottom:1px solid #f0f0f0;
        margin-bottom:12px;
      }

      /* === Etiqueta de campo === */
      .field-label {
        font-size:11.5px; font-weight:600; color:#555;
        margin-bottom:6px; display:block;
      }

      /* === Input con ícono mejorado === */
      .input-with-icon {
        position:relative;
      }
      .input-with-icon i {
        position:absolute; left:10px; top:50%;
        transform:translateY(-50%);
        color:#f59800; font-size:13px; pointer-events:none;
      }
      .input-with-icon input {
        padding-left:32px !important;
      }

      /* === Mapa con borde naranja === */
      .map-container {
        border:1px solid #f0e0c0;
        border-radius:10px;
        overflow:hidden;
      }
    </style>
  </head>

  <body style="height:100% !important;">

    <div class="loader-indices">
      <div class="loader">
        <img src="../assets/images/logo/logo-perhusa.png" alt="">
      </div>
    </div>

    <div class="page-wrapper compact-wrapper" id="pageWrapper">

      <!-- Page Header -->
      <div class="page-header">
        <div class="header-wrapper row m-0">

          <div class="header-logo-wrapper col-auto p-0">
            <div class="logo-wrapper">
              <div class="hm-badge">
                <div class="hm-icon">
                  <svg width="15" height="15" viewBox="0 0 32 32" fill="none">
                    <path d="M16 6C10 6,5 11,5 17.5C5 23.5,10 28,16 28C22 28,27 23.5,27 17.5C27 11,22 6,16 6Z" fill="rgba(255,255,255,0.93)"/>
                    <path d="M16 6C16 6,17.5 2.5,21.5 3.5" stroke="rgba(255,255,255,0.65)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
                  </svg>
                </div>
                <span class="hm-text">Parcelas de Mango</span>
              </div>
            </div>
            <div class="toggle-sidebar">
              <i class="status_toggle middle sidebar-toggle" data-feather="align-center"></i>
            </div>
          </div>

          <div class="left-header col-7 horizontal-wrapper ps-0">
            <a class="sidebar-link sidebar-title" href="javascript:void(0)"><i data-feather="bar-chart"></i><span>Dashboard</span></a>
            <a class="sidebar-link sidebar-title" href="javascript:void(0)"><i data-feather="map"></i><span>Monitoreo</span></a>
            <a class="sidebar-link sidebar-title" href="javascript:void(0)"><i data-feather="layers"></i><span>Coberturas</span></a>
            <a class="sidebar-link sidebar-title" href="javascript:void(0)"><i data-feather="file-text"></i><span>Reportes</span></a>
          </div>

          <div class="nav-right col-3 pull-right right-header p-0">
            <ul class="nav-menus">
              <li class="onhover-dropdown">
                <div class="notification-box"><i class="fa fa-bell-o"></i><span class="badge rounded-pill badge-primary">4</span></div>
                <ul class="notification-dropdown onhover-show-div">
                  <li><i data-feather="bell"></i><h6 class="f-18 mb-0">Notificaciones</h6></li>
                  <li><a href="email_read.html"><p><i class="fa fa-circle-o me-3 font-primary"></i>Solicitud NDVI <span class="pull-right">10 min.</span></p></a></li>
                  <li><a href="email_read.html"><p><i class="fa fa-circle-o me-3 font-success"></i>Solicitud RECI<span class="pull-right">1 hr</span></p></a></li>
                  <li><a href="email_read.html"><p><i class="fa fa-circle-o me-3 font-info"></i>Solicitud MCARI<span class="pull-right">3 hr</span></p></a></li>
                  <li><a href="email_read.html"><p><i class="fa fa-circle-o me-3 font-danger"></i>Solicitud EVI<span class="pull-right">6 hr</span></p></a></li>
                  <li><a class="btn btn-primary" href="email_read.html">Ver más</a></li>
                </ul>
              </li>
            </ul>
          </div>

          <script class="result-template" type="text/x-handlebars-template">
            <div class="ProfileCard u-cf">
            <div class="ProfileCard-avatar"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-airplay m-0"><path d="M5 17H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-1"></path><polygon points="12 15 17 21 7 21 12 15"></polygon></svg></div>
            <div class="ProfileCard-details"><div class="ProfileCard-realName">{{name}}</div></div>
            </div>
          </script>
          <script class="empty-template" type="text/x-handlebars-template">
            <div class="EmptyMessage">Your search turned up 0 results. This most likely means the backend is down, yikes!</div>
          </script>
        </div>
      </div>
      <!-- Page Header Ends -->

      <div class="page-body-wrapper">

        <%- include('./partials/menu_lateral'); %>

        <div class="page-body">
          <div class="container-fluid">
            <div class="row h-100 m-0">

              <!-- PANEL IZQUIERDO -->
              <div class="col-xl-3 col-md-3 box-col-30 xl-30 info-section">
                <div class="card">
                  <div class="card-body">

                    <div class="logo-section mb-4">
                      <%- include('./partials/user_profile'); %>
                    </div>

                    <div class="title-module-section">
                      <div class="group-title-module" style="display:flex;">
                        <a class="a-open-menu" style="margin-right:10px; margin-top:2px;">
                          <span class="fa fa-bars"></span>
                        </a>
                        <div class="item-title-module">
                          <small>Módulo</small>
                          <h5 class="mb-0">Administración de Datos</h5>
                        </div>
                      </div>
                    </div>

                    <div class="options-section">
                      <div class="buscador-periodo-ie-section">
                        <%- include('./partials/admin_menu'); %>
                      </div>
                    </div>

                  </div>
                </div>
              </div>

              <!-- PANEL DERECHO -->
              <div class="col-xl-9 col-md-9 box-col-70 xl-70 admin-data-section">
                <div class="card">
                  <div class="card-body p-5">

                    <!-- Encabezado mejorado -->
                    <div class="section-header-mango">
                      <div class="sh-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 2C8 2,5 6,5 10.5C5 15,8 19,12 20C16 19,19 15,19 10.5C19 6,16 2,12 2Z"/>
                          <path d="M12 2C12 2,13.5 0,16 0.5" stroke-opacity="0.6"/>
                          <line x1="12" y1="20" x2="12" y2="24"/>
                        </svg>
                      </div>
                      <div class="sh-text">
                        <h5>Agregar nuevas parcelas</h5>
                        <small>Busca, previsualiza y registra una nueva parcela en el sistema</small>
                      </div>
                    </div>

                    <div class="row">

                      <!-- Columna izquierda: buscador + mapa -->
                      <div class="col-xl-6 col-md-6 box-col-50 xl-50">

                        <!-- Buscador -->
                        <div class="buscador-parcela-section mb-4">
                          <div class="form-subsection">
                            <h6>Buscador de Parcelas</h6>
                          </div>
                          <div class="search">
                            <form class="form-inline w-100">
                              <div class="form-group d-flex mb-0 w-100 ui search">
                                <i class="fa fa-search"></i>
                                <input class="form-control-plaintext input-buscar-parcela" type="text" placeholder="Ingresa el nombre, código o DNI">
                                <div class="dropdown-content">
                                  <ul class="list-group list-group-flush list"></ul>
                                </div>
                              </div>
                            </form>
                          </div>
                        </div>

                        <!-- Mapa previsualización — id y clases originales intactas -->
                        <div class="mt-2">
                          <div class="form-subsection">
                            <h6>Previsualización de Parcela</h6>
                          </div>
                          <div class="map-container">
                            <div id="map"></div>
                          </div>
                        </div>

                      </div>

                      <!-- Columna derecha: formulario -->
                      <div class="col-xl-6 col-md-6 box-col-50 xl-50">

                        <div class="form-subsection mb-1">
                          <h6>Datos de la Parcela</h6>
                        </div>

                        <!-- Nombre -->
                        <div class="input-section mb-4">
                          <label class="field-label">Nombre de Parcela</label>
                          <div class="search">
                            <form class="form-inline w-100">
                              <div class="form-group d-flex mb-0 w-100 ui search">
                                <i class="fa fa-seedling"></i>
                                <input class="form-control-plaintext input-nombre-agregar-parcela" type="text" placeholder="Ingresar nombre de parcela">
                              </div>
                            </form>
                          </div>
                        </div>

                        <!-- Productor -->
                        <div class="input-section mb-4">
                          <label class="field-label">Productor(a)</label>
                          <select id="select-input-productor-agregar-parcela" class="js-example-basic-single input-select col-sm-12" data-model="productores" data-id=""></select>
                        </div>

                        <!-- Variedad -->
                        <div class="input-section mb-4">
                          <label class="field-label">Variedad</label>
                          <select id="select-input-variedad-agregar-parcela" class="js-example-basic-single input-select col-sm-12" data-model="variedades" data-id=""></select>
                        </div>

                        <!-- Zona -->
                        <div class="input-section mb-4">
                          <label class="field-label">Zona</label>
                          <select id="select-input-zona-agregar-parcela" class="js-example-basic-single input-select col-sm-12" data-model="zonas" data-id=""></select>
                        </div>

                        <!-- Botones de acción — clases e IDs originales intactos -->
                        <div class="footer-section" style="position:relative; padding-left:0; justify-content:flex-start; display:flex; align-items:center; gap:8px; flex-wrap:wrap;">

                          <button id="btnCalcularInterseccion" class="btn btn-back btn-sm btn-calcular-interseccion" type="button">
                            <i class="fa fa-draw-polygon me-1"></i> Calcular Intersección
                          </button>

                          <form id="csvForm" enctype="multipart/form-data" class="d-flex flex-column" style="position:relative;">
                            <input type="file" name="csvFile" id="csvFile" accept=".csv" class="d-none">
                            <button id="cargarCSV" class="btn btn-back btn-cargar-csv-parcela m-r-10" type="button">
                              <i class="fa fa-upload me-1"></i> Cargar CSV
                            </button>
                            <span id="progreso" style="position:absolute;bottom:-18px;left:0;color:#888;font-size:11px;">0%</span>
                          </form>

                          <button class="btn btn-primary btn-agregar-parcela" type="button" disabled>
                            <i class="fa fa-plus me-1"></i> Agregar
                          </button>

                        </div>

                      </div>

                    </div>

                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- Footer — sin cambios -->
        <footer class="footer">
          <div class="container-fluid">
            <div class="row">
              <div class="col-md-6 p-0 footer-left">
                <p class="mb-0">Copyright© 2026 TraZar. Todos los derechos</p>
              </div>
            </div>
          </div>
        </footer>

      </div>
    </div>

    <!-- Modal fechas — sin cambios -->
    <div class="modal fade" id="modal-fechas-imagenes" tabindex="-1" aria-labelledby="exampleModalCenter" aria-modal="true" role="dialog">
      <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Fechas disponibles</h5>
            <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p>Seleccionar la fecha para mostrar el análisis.</p>
            <div class="div-radiobuttons-wrapper"></div>
          </div>
          <div class="modal-footer">
            <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Cerrar</button>
            <button class="btn btn-primary seleccionar-fecha" type="button">Seleccionar periodo</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Scripts — orden exacto del original -->
    <script src="../assets/js/jquery-3.6.0.min.js"></script>
    <script src="../assets/js/bootstrap/bootstrap.bundle.min.js"></script>
    <script src="../assets/js/icons/feather-icon/feather.min.js"></script>
    <script src="../assets/js/icons/feather-icon/feather-icon.js"></script>
    <script src="../assets/js/scrollbar/simplebar.js"></script>
    <script src="../assets/js/scrollbar/custom.js"></script>
    <script src="../assets/js/config.js"></script>
    <script src="../assets/js/select2/select2.full.min.js"></script>
    <script src="../assets/js/select2/select2-custom.js"></script>
    <script src="../assets/js/chart/chartist/chartist.js"></script>
    <script src="../assets/js/chart/chartist/chartist-plugin-tooltip.js"></script>
    <script src="../assets/js/chart/knob/knob.min.js"></script>
    <script src="../assets/js/chart/knob/knob-chart.js"></script>
    <script src="../assets/js/chart/apex-chart/apex-chart.js"></script>
    <script src="../assets/js/chart/apex-chart/stock-prices.js"></script>
    <script src="../assets/js/prism/prism.min.js"></script>
    <script src="../assets/js/clipboard/clipboard.min.js"></script>
    <script src="../assets/js/custom-card/custom-card.js"></script>
    <script src="../assets/js/notify/bootstrap-notify.min.js"></script>
    <script src="../assets/js/dashboard/default.js"></script>
    <script src="../assets/js/slick-slider/slick.min.js"></script>
    <script src="../assets/js/slick-slider/slick-theme.js"></script>
    <script src="../assets/js/datepicker/date-picker/datepicker.js"></script>
    <script src="../assets/js/datepicker/date-picker/datepicker.en.js"></script>
    <script src="../assets/js/datepicker/date-picker/datepicker.custom.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="../assets/js/script.js"></script>
    <script src="../js/tools-script.js"></script>
    <script src="../js/capas-de-datos.js"></script>
    <script src="../js/admin-datos/admin-datos-script.js"></script>
    <script src="../js/admin-datos/agregar-parcela-script.js"></script>

    <%- include('./partials/scripts'); %>

  </body>
</html>