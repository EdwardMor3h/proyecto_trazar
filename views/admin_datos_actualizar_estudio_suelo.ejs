    <style>
      /* Header badge mango */
      .hm-badge { display:flex; align-items:center; gap:8px; }
      .hm-badge .hm-icon {
        width:28px; height:28px; flex-shrink:0;
        background:linear-gradient(135deg,#f5a800,#e06800);
        border-radius:6px;
        display:flex; align-items:center; justify-content:center;
      }
      .hm-badge .hm-text { font-weight:700; font-size:13px; white-space:nowrap; }

      /* Título módulo */
      .title-module-section {
        border-left: 3px solid #f59800;
        padding-left: 10px;
        margin-bottom: 20px;
      }
      .item-title-module small { font-size:10px; color:#888; text-transform:uppercase; letter-spacing:0.06em; }
      .item-title-module h5    { font-size:15px; font-weight:700; margin-top:2px; }

      /* Encabezado sección */
      .section-header-mango {
        display:flex; align-items:center; gap:14px;
        margin-bottom:20px; padding-bottom:16px;
        border-bottom:2px solid #f5f5f5;
      }
      .section-header-mango .sh-icon {
        width:42px; height:42px; flex-shrink:0;
        background:linear-gradient(135deg,#f5a800,#e06800);
        border-radius:10px;
        display:flex; align-items:center; justify-content:center;
        box-shadow:0 2px 8px rgba(245,152,0,0.3);
      }
      .section-header-mango .sh-text h5  { font-size:16px; font-weight:700; margin:0; }
      .section-header-mango .sh-text small { color:#888; font-size:12px; }

      /* Buscador separado */
      .buscador-card {
        background: #fffbf5;
        border: 1px solid #f0e0c0;
        border-radius: 10px;
        padding: 14px 16px;
        margin-bottom: 24px;
      }
      .buscador-card h6 {
        font-size:11px; font-weight:700; text-transform:uppercase;
        letter-spacing:0.07em; color:#b36800; margin-bottom:10px;
      }

      /* Grupos de campos */
      .field-group {
        margin-bottom: 18px;
      }
      .field-group .field-label {
        font-size:11.5px; font-weight:600; color:#555;
        margin-bottom:6px; display:block;
      }
      .field-group .field-unit {
        font-size:10px; color:#aaa; font-weight:400;
        margin-left:4px; letter-spacing:0.04em;
      }

      /* Separador de columnas */
      .col-divider {
        border-left: 1px solid #f0f0f0;
        padding-left: 24px !important;
      }

      /* Ícono dentro del input — naranja */
      .form-group i.fa { color: #f59800 !important; }

      /* === Panel izquierdo — logo section banner mango === */
      .logo-section {
        background: linear-gradient(135deg, #1b3d10, #2e6318);
        border-radius: 10px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
      }
      .logo-section .logo-container { display:flex; align-items:center; gap:8px; }
      .logo-section .logo-container span { color:#fff; font-weight:700; font-size:13px; line-height:1.25; }
      .logo-section .logo-container small { color:#ffc046; font-size:10px; display:block; font-weight:500; }

      /* === Secciones del menú lateral === */
      .nuevos-datos-section h6 {
        font-size:10.5px; font-weight:700; text-transform:uppercase;
        letter-spacing:0.08em; color:#888;
        padding-bottom:6px; border-bottom:1px solid #f0f0f0; margin-bottom:0;
      }
      .items-menu-container ul { list-style:none; padding:0; margin:0; }
      .items-menu-container ul li { margin-bottom:2px; }
      .items-menu-container ul li a {
        display:flex; align-items:center; gap:8px;
        padding:7px 10px; border-radius:7px;
        font-size:13px; color:inherit; text-decoration:none;
        transition:background 0.18s, color 0.18s;
      }
      .items-menu-container ul li a:hover { background:#fff8ed; color:#e07000; }
      .items-menu-container ul li a.active {
        background:linear-gradient(135deg,rgba(245,168,0,0.15),rgba(245,168,0,0.07));
        color:#c96800; font-weight:600;
        border-left:3px solid #f59800; padding-left:7px;
      }
      .items-menu-container ul li a i { font-size:12px; width:14px; text-align:center; color:#f59800; }

    </style>
  </head>

  <body style="height:100% !important;">

    <div class="loader-indices">
      <div class="loader">
        <img src="../assets/images/img-logo-geofarms.png" alt="">
