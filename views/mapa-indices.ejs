                            </div>
                            <div class="d-flex mb-4">
                              <label class="col-form-label m-r-10"><i class="fa fa-satellite"></i> &nbsp 10 de Noviembre del 2022</label>
                              <div class="flex-grow-1 text-end icon-state">
                                <label class="switch switch-fechas-disponibles"><input type="checkbox" value="10-11-22"><span class="switch-state"></span></label>
                              </div>
                            </div>
                            <div class="d-flex mb-4">
                              <label class="col-form-label m-r-10"><i class="fa fa-satellite"></i> &nbsp 11 de Noviembre del 2022</label>
                              <div class="flex-grow-1 text-end icon-state">
